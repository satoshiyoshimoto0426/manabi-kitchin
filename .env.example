# ==========================================================
# ManabiOps 環境変数サンプル
# - 本番運用時は Google Secret Manager で管理すること (要件定義 第5章)
# - 値を未設定の項目はモック動作に自動フォールバック
# ==========================================================

# --- Runtime ---
PORT=8080
NODE_ENV=development
# モック強制モード (true にすると外部APIを一切呼ばない)
MOCK_MODE=true

# --- LINE Messaging API (FR-05, 外部I/F) ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- Google Cloud 共通 ---
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# --- Gemini (FR-01, FR-02 科目推論, FR-08 キャプション) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Document AI (FR-02, FR-04 OCR) ---
DOCAI_LOCATION=us
DOCAI_RECEIPT_PROCESSOR_ID=
DOCAI_ROSTER_PROCESSOR_ID=

# --- Firestore (データ要件 第7章) ---
FIRESTORE_DATABASE_ID=(default)

# --- Cloud Storage (media, EX-11) ---
GCS_BUCKET_MEDIA=

# --- Google Sheets (FR-03 会計台帳) ---
SHEETS_SPREADSHEET_ID=
SHEETS_LEDGER_NAME=会計台帳

# --- Instagram Graph API (FR-10) ---
IG_BUSINESS_ACCOUNT_ID=
IG_ACCESS_TOKEN=

# --- セキュリティ (第5章・第6章) ---
# 参加者氏名ハッシュ用ソルト (SHA-256)
PARTICIPANT_HASH_SALT=change-me-in-production
# 氏名暗号化用キー (32byte hex)
PARTICIPANT_ENC_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
# 管理画面ベーシック認証
ADMIN_USER=admin
ADMIN_PASSWORD=manabi-admin-change-me

# --- OCR信頼度閾値 (EX-01) ---
OCR_CONFIDENCE_THRESHOLD=0.70

# --- Owner 通知先 (EX-03, EX-11 メール) ---
OWNER_EMAIL=
